{
  "name": "@nanostores/deepmap",
  "version": "0.0.1",
  "description": "A helper for Nanostores to create deep maps",
  "keywords": [
    "store",
    "state",
    "nanostores",
    "deepmap",
    "state manager",
    "react",
    "react native",
    "preact",
    "vue",
    "svelte"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch deep-map/deepmap.test.ts",
    "test:lint": "eslint .",
    "test:types": "check-dts",
    "test:coverage": "vitest run --coverage",
    "test": "pnpm run /^test:/"
  },
  "author": "Edgar Sanchez <albertolifo@gmail.com>",
  "license": "MIT",
  "repository": "nanostores/deep-map",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "engines": {
    "node": "^20.0.0 || >=22.0.0"
  },
  "peerDependencies": {
    "nanostores": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@vitest/coverage-v8": "^4.0.9",
    "check-dts": "^0.9.0",
    "eslint": "^9.39.1",
    "jiti": "^2.6.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.0.9"
  }
}
