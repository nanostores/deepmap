{
  "name": "@nanostores/deep-map",
  "version": "0.0.1",
  "description": "A helper for Nanostores to create deep maps",
  "keywords": [
    "store",
    "state",
    "nanostores",
    "deepmap",
    "state manager",
    "react",
    "react native",
    "preact",
    "vue",
    "svelte"
  ],
  "scripts": {
    "dev": "tsx watch TEST/deepmap.test.ts",
    "test:lint": "eslint .",
    "test:types": "check-dts",
    "test:size": "size-limit",
    "test": "pnpm run /^test:/"
  },
  "author": "Andrey Sitnik <andrey@sitnik.ru>",
  "license": "MIT",
  "repository": "nanostores/nanostores",
  "sideEffects": false,
  "type": "module",
  "types": "./index.d.ts",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": "^20.0.0 || >=22.0.0"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/ai"
    }
  ],
  "peerDependencies": {
    "nanostores": "^1.0.0"
  },
  "devDependencies": {
    "@logux/eslint-config": "^56.1.0",
    "@sinonjs/fake-timers": "^15.0.0",
    "@size-limit/preset-small-lib": "^11.2.0",
    "@types/node": "^24.9.1",
    "@types/sinonjs__fake-timers": "^15.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "actions-up": "^1.4.2",
    "benchmark": "^2.1.4",
    "better-node-test": "^0.8.3",
    "check-dts": "^0.9.0",
    "clean-publish": "^6.0.0",
    "eslint": "^9.38.0",
    "multiocular": "^0.8.1",
    "nanodelay": "^2.0.2",
    "size-limit": "^11.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "prettier": {
    "arrowParens": "avoid",
    "jsxSingleQuote": false,
    "quoteProps": "consistent",
    "semi": false,
    "singleQuote": true,
    "trailingComma": "none"
  },
  "size-limit": [
    {
      "name": "deep-map",
      "import": {
        "./index.js": "{ deepMap }"
      },
      "limit": "1.5 KB"
    }
  ],
  "clean-publish": {
    "cleanDocs": true
  }
}